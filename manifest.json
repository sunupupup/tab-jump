{
  "manifest_version": 3,
  "name": "Tab Jump",
  "version": "1.0.0",
  "description": "快速跳转到指定Tab或网站 - 按下快捷键，输入关键词即可跳转",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tab Jump (Alt+J)"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+J"
      },
      "description": "打开 Tab Jump 搜索框"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js"
  }
}
